# ============================================================
# Decibel 网格交易机器人 - 环境变量配置
# 复制此文件为 .env 并填入你的实际值
# ============================================================

# ---- 网络配置 ----
NETWORK=mainnet
FULLNODE_URL=https://fullnode.mainnet.aptoslabs.com/v1
DECIBEL_REST_URL=https://api.decibel.trade
DECIBEL_WS_URL=wss://api.decibel.trade

# ---- 钱包与认证 (必填) ----
# API 钱包私钥 (Ed25519), 从 Decibel App 导出
API_WALLET_PRIVATE_KEY=your_private_key_here
# API 钱包地址
API_WALLET_ADDRESS=0xyour_wallet_address_here
# 子账户地址 (trading subaccount)
SUBACCOUNT_ADDRESS=0xyour_subaccount_address_here
# Bearer Token, 从 Geomi (geomi.dev) 获取 (可选但建议填写)
API_BEARER_TOKEN=your_bearer_token_here

# ---- Builder 归因 (可选, 用于交易量归属和返佣) ----
BUILDER_ADDRESS=
BUILDER_FEE_BPS=0

# ---- 交易市场 ----
MARKET_NAME=BTC/USD

# ---- 网格策略参数 ----
# 网格上边界价格 (USD)
GRID_UPPER_PRICE=70000
# 网格下边界价格 (USD)
GRID_LOWER_PRICE=60000
# 网格数量 (会生成 GRID_COUNT+1 个价位, 低于当前价挂买单, 高于挂卖单)
GRID_COUNT=10
# 每档下单数量 (合约数量)
ORDER_SIZE=0.001

# ---- 运行参数 ----
# 轮询间隔 (毫秒)
POLL_INTERVAL_MS=5000
# 最大重试次数
MAX_RETRIES=3
# 重试延迟 (毫秒)
RETRY_DELAY_MS=2000
